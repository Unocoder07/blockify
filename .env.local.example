# Copy this file to `.env.local` and set a strong value before deploying.

# Token required to access the testimonial moderation dashboard at
# /admin/testimonials and the admin API routes. In development, if this is
# unset the app falls back to "blockify-admin".
ADMIN_TOKEN=change-me-to-a-long-random-string

# Upstash Redis — persistent, serverless-friendly store for the live
# "Website Visits" / "Beta Downloads" counters on the landing page.
# Create a free database at https://upstash.com (or via the Vercel
# Marketplace) and paste the REST credentials here. If these are unset, the
# app falls back to in-memory counters that reset on restart (fine for local
# dev, but numbers will NOT persist in production without these).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
